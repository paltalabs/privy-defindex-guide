# Privy — server wallet credentials
# Create a Privy app at https://dashboard.privy.io
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Authorization key (P-256 keypair)
# Generate via: pnpm keygen
# OR create in Privy Dashboard → Wallets → Authorization keys → New key
# Format:  wallet-auth:<base64-PKCS8-DER>
PRIVY_AUTHORIZATION_PRIVATE_KEY=

# Defindex API
# Obtain from the Defindex team
DEFINDEX_API_KEY=

# Stellar — server key for XLM sponsorship (mainnet only, for 06-full-bridge.ts)
# Must hold ≥ 5 XLM on Stellar mainnet
STELLAR_SERVER_KEY=

# Base RPC (mainnet)
BASE_RPC_URL=https://mainnet.base.org
